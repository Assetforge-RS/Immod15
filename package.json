{
  "name": "immobilien-bewertung",
  "version": "1.0.0",
  "description": "Professionelle Immobilienbewertungs-Web-App mit PDF-Export",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
